# --- Primary database: Supabase Postgres (see ../../SUPABASE.md) ---
# --- PostgreSQL (local only for dev, optional) ---
# Supabase: Dashboard → Project Settings → Database → Connection string → URI
# Example (direct, port 5432):
#   postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# Or "Direct connection" host db.[PROJECT_REF].supabase.co:5432
#
# Tip: append ?sslmode=require if your client needs it (TypeORM also enables SSL when host contains supabase.co)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Optional: override SSL (auto ON for *.supabase.co / *.supabase.com when unset)
# DATABASE_SSL=true
# DATABASE_SSL=false

# TypeORM: create/update tables from entities. Use false in production after you trust migrations.
TYPEORM_SYNC=true

# Must be true for Nest to load TypeORM, auth, users, etc.
ENABLE_DB=true

ENABLE_QUEUE=false
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=HSPTS Backend
GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/1cgPq-M2cGkyElpf9ORcbp4uK-YhuHSODj00aTN9XZzg/edit?usp=sharing

# JWT (when ENABLE_DB=true)
AUTH_JWT_SECRET=
JWT_SECRET=
JWT_EXPIRES_IN=7d

# SMTP (optional)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# Admin seed (optional)
# ADMIN_EMAIL=
# ADMIN_PASSWORD=

# CORS + email links (comma-separated origins allowed)
# FRONTEND_URL=https://your-app.vercel.app,http://localhost:3000
