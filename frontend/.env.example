# --- Local / Vercel (see ../VERCEL_ENV.md and vercel.env.example) ---
NEXT_PUBLIC_API_BASE_URL=/api
NEXT_PUBLIC_USE_AUTH_API=false

# Supabase (browser client; optional)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# --- Server-only (Next.js API routes; set in Vercel or .env.local for local API routes) ---
BACKEND_API_URL=http://localhost:3001/api

# Google Sheet
NEXT_PUBLIC_GOOGLE_SHEET_URL=

# OpenRouter (analysis)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=HSPTS
