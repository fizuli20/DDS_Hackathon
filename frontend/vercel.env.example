# Copy to vercel.env.production.local, fill values, then run:
#   powershell -ExecutionPolicy Bypass -File .\scripts\vercel-push-env.ps1 -Environment production
# Do not commit *.local files.

# --- Server (Next.js API routes) — Nest backend base URL, must end with /api ---
BACKEND_API_URL=https://YOUR_NEST_HOST.example.com/api

# --- Browser: same-origin proxy is usually /api ---
NEXT_PUBLIC_API_BASE_URL=/api

# --- Real auth (Nest + DB) ---
NEXT_PUBLIC_USE_AUTH_API=true

# --- Supabase (optional client) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# --- Google Sheet (dashboard data) ---
NEXT_PUBLIC_GOOGLE_SHEET_URL=

# --- OpenRouter (analysis routes; keep secret in Vercel) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=https://YOUR_VERCEL_APP.vercel.app
OPENROUTER_APP_NAME=HSPTS
